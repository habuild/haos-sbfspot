#!/usr/bin/with-contenv bashio
# ==============================================================================
# Start the cron service
# s6-overlay docs: https://github.com/just-containers/s6-overlay
# ==============================================================================

CONFIG_PATH=/data/options.json

USERTIME="$(jq --raw-output '.usertime // "*/5" ' $CONFIG_PATH)"
DURATION="$(jq --raw-output '.duration // "6-21" ' $CONFIG_PATH)"
SQL="$(jq --raw-output '.sql // "ad1" ' $CONFIG_PATH)"

# Clear crontab to start so no accidental duplicates
crontab -r

# Set SBFspot runtimes
var="$(jq --raw-output '.Timer' $CONFIG_PATH)"
if bashio::var.equals "${var}" "5min"; then
   bashio::log.yellow '|   Starting SBFspot for every 5th minute   |'
   echo "*/5 6-22 * * * /usr/bin/sbfspot/SBFspot -v -${SQL} -mqtt > /dev/stdout" >> /etc/crontabs/root

elif bashio::var.equals "${var}" "1min"; then
     bashio::log.magenta '|   Starting SBFspot for every 1 minute   |'
     echo "*/1 6-22 * * * /usr/bin/sbfspot/SBFspot -v -${SQL} -mqtt /dev/stdout" >> /etc/crontabs/root
UT= true
elif bashio::var.equals "${var}" "UT"; then
     bashio::log.red "|    Starting SBFspot for every ${USERTIME} minutes   |"
     bashio::log.red "|            Between hours  ${DURATION}             |"
     echo "${USERTIME} ${DURATION} * * * /usr/bin/sbfspot/SBFspot -v -${SQL} -mqtt /dev/stdout" >> /etc/crontabs/root
else
     bashio::log.cyan '|    No One knows how you got here    |'
     bashio::log.cyan '|     check your option selection     |'
fi

# Enable SBFspotUpload
var="$(jq --raw-output '.Upload' $CONFIG_PATH)"
if bashio::var.equals "${var}" "true"; then
   bashio::log.cyan '|   Starting SBFspotUpload  |'
   # start SBFspotUpload 1 min after boot
   echo '@reboot sleep 60 && /usr/bin/sbfspot/SBFspotUploadDaemon -c /usr/bin/sbfspot/SBFspotUpload.cfg /dev/stdout' >> /etc/crontabs/root
   # monthly data SBFspot archive upload at 5:55am now with -mqtt call
   echo '55 05 * * * /usr/bin/sbfspot/SBFspot -v -sp0 -ad14 -am1 -ae1 -mqtt -finq /dev/stdout' >> /etc/crontabs/root
fi
      
# update sensors after restart
echo '@reboot sleep 30 && /usr/bin/sbfspot/SBFspot -v -nosql -mqtt -finq > /dev/stdout' >> /etc/crontabs/root

echo "$(crontab -l) > /dev/stdout"